BoxLayout:
    orientation: "vertical"
    padding: 10
    spacing: 10

    TextInput:
        id: a
        hint_text: "Enter A"
        input_filter: "int"

    TextInput:
        id: b
        hint_text: "Enter B"
        input_filter: "int"

    TextInput:
        id: c
        hint_text: "Enter Steps (C)"
        input_filter: "int"

    TextInput:
        id: d
        hint_text: "Extra (D)"
        input_filter: "int"

    Button:
        text: "Calculate"
        on_press: root.calculate()

    Label:
        id: result
        text: "Result"

    ScrollView:
        TextInput:
            id: steps
            readonly: True
            size_hint_y: None
            height: self.minimum_height
